{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/agco/refs/heads/main/json-structure/agco-location-structure.json",
  "name": "MachineLocation",
  "description": "Historical location data point for an AGCO machine.",
  "type": "object",
  "properties": {
    "machine_id": {
      "type": "string",
      "description": "Machine identifier.",
      "example": "mach-500123"
    },
    "latitude": {
      "type": "double",
      "description": "Latitude in decimal degrees.",
      "example": 41.8781
    },
    "longitude": {
      "type": "double",
      "description": "Longitude in decimal degrees.",
      "example": -87.6298
    },
    "altitude": {
      "type": "double",
      "description": "Altitude in meters.",
      "example": 215.0
    },
    "heading": {
      "type": "double",
      "description": "Direction of travel in degrees (0-360).",
      "example": 45.0
    },
    "ground_speed": {
      "type": "double",
      "description": "Ground speed in km/h at this location.",
      "example": 8.5
    },
    "timestamp": {
      "type": "datetime",
      "description": "Location timestamp.",
      "example": "2025-04-01T10:30:00Z"
    }
  }
}